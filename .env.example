# ========================================
# STRENDUS WHATSAPP BOT - CONFIGURACIÓN
# ========================================

# WhatsApp Business API (Meta)
WHATSAPP_TOKEN=tu_token_permanente_de_waba_aqui
PHONE_NUMBER_ID=tu_phone_number_id_aqui
WEBHOOK_VERIFY_TOKEN=mi_token_secreto_strendus_2026

# The Odds API
ODDS_API_KEY=e6f9e72f5c01e0e3073cd2a3ad4d36f4

# OpenAI (para entender lenguaje libre del usuario)
OPENAI_API_KEY=sk-...

# Configuración del Servidor
PORT=3000
NODE_ENV=development

# API Fake de Strendus (autenticación interna)
STRENDUS_API_TOKEN=strendus_secret_token_2026_xyz

# URLs (ajustar según deploy)
BASE_URL=http://localhost:3000
STRENDUS_API_URL=http://localhost:3000/api/strendus

# Empresa
COMPANY_NAME=Strendus
COMPANY_WEBSITE=https://www.strendus.com
COMPANY_REGISTRATION_URL=https://www.strendus.com/registro

# ========================================
# INSTRUCCIONES
# ========================================
# 1. Copia este archivo como .env
# 2. Llena los valores de WHATSAPP_TOKEN y PHONE_NUMBER_ID desde Meta Business
# 3. El WEBHOOK_VERIFY_TOKEN lo creas tú (cualquier string único)
# 4. Para producción, cambia BASE_URL a tu dominio de Railway
